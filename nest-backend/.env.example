# =============================================================================
#  KYMA Mail backend configuration — copy to .env and fill in the values.
#  Never commit your real .env. Rotate every secret before going to production.
# =============================================================================

# ---------- Runtime -----------------------------------------------------------
# "development" or "production". Controls cookie.secure, helmet strictness,
# CORS/WebAuthn validation, and whether TypeORM auto-synchronizes the schema.
NODE_ENV=development

# HTTP port the API listens on (default 3300).
PORT=3300

# ---------- Database ----------------------------------------------------------
# Path (relative to nest-backend/) or absolute path to the SQLite file.
DB_PATH=settings.sqlite

# Set to "false" in production to disable TypeORM auto-sync. Schema changes
# should then go through proper migrations (not yet scripted in this repo).
DB_SYNC=true

# ---------- Secrets (REQUIRED in production) ----------------------------------
# Encryption key for at-rest secrets (IMAP/SMTP passwords, OAuth tokens,
# AI API keys, PGP private keys). AES-256-GCM. Must be 32 raw bytes.
# Generate with: openssl rand -hex 32
# In production, prefer ENCRYPTION_KEY_FILE so the .env alone cannot decrypt
# a stolen database.
ENCRYPTION_KEY=
# ENCRYPTION_KEY_FILE=/absolute/path/to/encryption.key

# Optional: previous encryption key, used ONLY to decrypt legacy values that
# were encrypted before you rotated ENCRYPTION_KEY. Remove once every row has
# been re-encrypted (the app does this transparently on every read/save).
# LEGACY_ENCRYPTION_KEY=
# LEGACY_ENCRYPTION_KEY_FILE=/absolute/path/to/legacy-encryption.key

# JWT signing key for access tokens. Minimum 32 characters.
# Generate with: openssl rand -hex 32
JWT_SECRET=

# Separate JWT signing key for refresh tokens. Strongly recommended to make it
# different from JWT_SECRET so leaking one doesn't invalidate the other.
# Generate with: openssl rand -hex 32
JWT_REFRESH_SECRET=

# bcrypt cost for password/refresh-token hashing. Valid range: 10..15. Higher
# is slower but safer. Default: 12.
BCRYPT_ROUNDS=12

# ---------- CORS --------------------------------------------------------------
# Comma-separated list of allowed origins for browser clients. The refresh
# cookie uses SameSite=Strict, so this MUST include the origin the frontend
# is served from. Example:
#   CORS_ORIGINS=https://mail.example.com,https://admin.example.com
CORS_ORIGINS=http://localhost:4200,http://localhost:4000

# ---------- WebAuthn / Passkeys ----------------------------------------------
# Human-readable name displayed in the OS credential dialog.
WEBAUTHN_RP_NAME=KYMA Mail

# Relying-party ID. MUST be the registrable domain of your site (e.g.
# "example.com" for mail.example.com). Use "localhost" for local development.
WEBAUTHN_RP_ID=localhost

# Comma-separated list of accepted origins. In production these MUST be
# https://. Separate multiple entries with commas (no spaces).
#   WEBAUTHN_ORIGINS=https://mail.example.com
WEBAUTHN_ORIGINS=http://localhost:4200

# ---------- SMTP --------------------------------------------------------------
# Accept invalid / self-signed TLS certificates when sending via user-owned
# SMTP servers. Leave "false" unless you absolutely need the previous
# permissive behaviour. Set to "true" only for development with a local
# dev SMTP.
SMTP_ALLOW_INVALID_CERTS=false

# ---------- Web Push notifications -------------------------------------------
# VAPID keys identify the application server to push services (FCM, Mozilla,
# Apple). Generate ONCE with: npx web-push generate-vapid-keys
# Both keys are required to send pushes; missing them simply disables the
# feature server-side (subscriptions get refused with a clear error).
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=

# Contact for push services (mailto: URL or HTTPS URL). Apple in particular
# requires a valid mailto: here or pushes get dropped silently.
# VAPID_SUBJECT=mailto:admin@example.com

# Backend IMAP polling interval (in seconds), used as a fallback when IDLE
# is unavailable or the connection is bouncing. Default 300 (5 minutes).
# Lower values use more IMAP/CPU; higher values delay notifications.
# PUSH_POLL_INTERVAL_SECONDS=300

# Kill-switch for IMAP IDLE. Set to "true" to fall back to poll-only mode
# (e.g. for debugging or hosts that don't tolerate long-lived TCP).
# PUSH_DISABLE_IDLE=false

# ---------- OAuth-authenticated mail accounts (XOAUTH2) ----------------------
# Lets users add accounts that no longer accept Basic Auth on IMAP/SMTP, most
# notably personal Microsoft (live, hotmail, outlook) accounts since Sep 2024.
# Each provider requires a one-time app registration with the provider.
# Without these set, the "Se connecter avec ..." button stays hidden and only
# password-based accounts are offered.

# Microsoft (Azure App Registration → Personal + work/school accounts).
# Redirect URI to register: <your origin>/api/oauth-mail/microsoft/callback
# MICROSOFT_OAUTH_CLIENT_ID=
# MICROSOFT_OAUTH_TENANT=common

# Google (Google Cloud OAuth client, type "web application").
# Redirect URI to register: <your origin>/api/oauth-mail/google/callback
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=

# Override the redirect URI base when the public origin differs from the
# request host (e.g. behind a reverse proxy without X-Forwarded-Host).
# The provider name and "/callback" are appended automatically.
# OAUTH_MAIL_REDIRECT_URI=https://mail.example.com/api/oauth-mail
