# =============================================================================
#  MailFlow backend configuration — copy to .env and fill in the values.
#  Never commit your real .env. Rotate every secret before going to production.
# =============================================================================

# ---------- Runtime -----------------------------------------------------------
# "development" or "production". Controls cookie.secure, helmet strictness,
# CORS/WebAuthn validation, and whether TypeORM auto-synchronizes the schema.
NODE_ENV=development

# HTTP port the API listens on (default 3300).
PORT=3300

# ---------- Database ----------------------------------------------------------
# Path (relative to nest-backend/) or absolute path to the SQLite file.
DB_PATH=settings.sqlite

# Set to "false" in production to disable TypeORM auto-sync. Schema changes
# should then go through proper migrations (not yet scripted in this repo).
DB_SYNC=true

# ---------- Secrets (REQUIRED in production) ----------------------------------
# Encryption key for at-rest secrets (IMAP/SMTP passwords, OAuth tokens,
# AI API keys, PGP private keys). AES-256-GCM. Must be 32 raw bytes.
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# Optional: previous encryption key, used ONLY to decrypt legacy values that
# were encrypted before you rotated ENCRYPTION_KEY. Remove once every row has
# been re-encrypted (the app does this transparently on every read/save).
# LEGACY_ENCRYPTION_KEY=

# JWT signing key for access tokens. Minimum 32 characters.
# Generate with: openssl rand -hex 32
JWT_SECRET=

# Separate JWT signing key for refresh tokens. Strongly recommended to make it
# different from JWT_SECRET so leaking one doesn't invalidate the other.
# Generate with: openssl rand -hex 32
JWT_REFRESH_SECRET=

# bcrypt cost for password/refresh-token hashing. Valid range: 10..15. Higher
# is slower but safer. Default: 12.
BCRYPT_ROUNDS=12

# ---------- CORS --------------------------------------------------------------
# Comma-separated list of allowed origins for browser clients. The refresh
# cookie uses SameSite=Strict, so this MUST include the origin the frontend
# is served from. Example:
#   CORS_ORIGINS=https://mail.example.com,https://admin.example.com
CORS_ORIGINS=http://localhost:4200,http://localhost:4000

# ---------- WebAuthn / Passkeys ----------------------------------------------
# Human-readable name displayed in the OS credential dialog.
WEBAUTHN_RP_NAME=MailFlow

# Relying-party ID. MUST be the registrable domain of your site (e.g.
# "example.com" for mail.example.com). Use "localhost" for local development.
WEBAUTHN_RP_ID=localhost

# Comma-separated list of accepted origins. In production these MUST be
# https://. Separate multiple entries with commas (no spaces).
#   WEBAUTHN_ORIGINS=https://mail.example.com
WEBAUTHN_ORIGINS=http://localhost:4200

# ---------- SMTP --------------------------------------------------------------
# Accept invalid / self-signed TLS certificates when sending via user-owned
# SMTP servers. Leave "false" unless you absolutely need the previous
# permissive behaviour. Set to "true" only for development with a local
# dev SMTP.
SMTP_ALLOW_INVALID_CERTS=false
